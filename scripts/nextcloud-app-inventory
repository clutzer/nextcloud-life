#!/usr/bin/env python3
"""
Nextcloud App Inventory Script

Usage:
  python3 nextcloud-app-inventory                   # Print inventory only (safe)
  python3 nextcloud-app-inventory --save            # Print + save current state as desired config
"""

import json
import sys
import os
import argparse
from datetime import datetime
from subprocess import check_output

NC_DIR = "/var/www/nextcloud"
OCC = ["sudo", "-u", "www-data", "php", f"{NC_DIR}/occ"]
CONFIG = os.path.expanduser("~/.config/nextcloud-apps.conf")

def run_occ(*args):
    try:
        return check_output([*OCC, *args], text=True)
    except Exception as e:
        print(f"Error running occ: {e}")
        sys.exit(1)

def get_app_list():
    output = run_occ("app:list", "--output=json")
    try:
        return json.loads(output)
    except json.JSONDecodeError:
        print("Failed to parse occ JSON output.")
        sys.exit(1)

def print_inventory():
    print("=== Nextcloud App Inventory ===")
    print(f"Current status as of {datetime.now().strftime('%Y-%m-%d %H:%M:%S %Z')}")
    print(run_occ("app:list", "--output=plain").strip())

def save_desired_state():
    data = get_app_list()
    os.makedirs(os.path.dirname(CONFIG), exist_ok=True)

    with open(CONFIG, "w") as f:
        f.write("# Nextcloud App Desired State Configuration\n")
        f.write("# Format:  app_id = enable|disable|ignore   # comment\n")
        f.write("# Edit this file, then run 'nextcloud-app-enforce --enforce'\n\n")

        for section in ["enabled", "disabled"]:
            if section in data:
                for app, version in sorted(data[section].items()):
                    state = "enable" if section == "enabled" else "disable"
                    f.write(f'{app} = {state}  # {version}\n')

    print(f"\n✅ Desired state saved to: {CONFIG}")

def main():
    parser = argparse.ArgumentParser(description="Nextcloud App Inventory Tool")
    parser.add_argument("--save", action="store_true", help="Save current inventory as desired state config")
    args = parser.parse_args()

    print_inventory()

    if args.save:
        save_desired_state()
    else:
        print("\nTo save current inventory as desired state, run:")
        print("   python3 nextcloud-app-inventory --save")

if __name__ == "__main__":
    main()
