#!/bin/bash

# Configuration
OCC="sudo -u www-data /usr/bin/php /var/www/nextcloud/occ"
TARGET_VERSION="28.0.14"

# Start the timer
START_TIME=$(date +%s)

# Helper function for version comparison
# Returns 0 (true) if $1 is >= $2
version_ge() {
    # Test: if the lowest version in a sorted list is the target, 
    # then the current version is >= target.
    [ "$2" = "$(printf "$1\n$2" | sort -V | head -n1)" ]
}

echo "--- Starting Nextcloud Post-Upgrade Fixups ---"

# 1. Database Fixups
echo -n "Checking for missing columns... "
$OCC db:add-missing-columns -q && echo "Done."

echo -n "Checking for missing indices... "
$OCC db:add-missing-indices -q && echo "Done."

echo -n "Checking for missing primary keys... "
$OCC db:add-missing-primary-keys -q && echo "Done."

# 2. Extract Version and Determine Flags
# We use .version for the most granular comparison (28.0.14.1)
CURRENT_VERSION=$($OCC status --output=json 2>/dev/null | jq -r '.version')

REPAIR_FLAGS=""
if version_ge "$CURRENT_VERSION" "$TARGET_VERSION"; then
    echo "Nextcloud $CURRENT_VERSION detected (>= $TARGET_VERSION). Including --include-expensive."
    REPAIR_FLAGS="--include-expensive"
else
    echo "Nextcloud $CURRENT_VERSION detected. Skipping expensive repairs."
fi

# 3. Maintenance Repair
echo "Running maintenance repair (this may take a moment)..."
$OCC maintenance:repair $REPAIR_FLAGS

# 4. Completion and Timing
END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

echo
echo "--- Fixups Complete ---"
$OCC -V
echo "Total execution time: ${ELAPSED} seconds."
